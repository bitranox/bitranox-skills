# Shell scripts MUST stay LF or Git Bash on Windows cannot execute them
# (a CRLF run-python.sh fails with "cannot execute: required file not found"
# or "$'\r': command not found", silently disabling the self-improve gate).
*.sh text eol=lf
# Python hook/skill scripts: normalize to LF for consistent hashing & execution.
*.py text eol=lf
# Keep hook/plugin config LF too.
*.json text eol=lf
# subagent-driven-development ships extensionless bash helper scripts (run as scripts/<name>);
# pin them LF so Git Bash on Windows can execute them (the *.sh rule cannot match a name with no extension).
plugins/bitranox/skills/subagent-driven-development/scripts/* text eol=lf
# Let git decide for everything else.
* text=auto
